[Unit]
Description=ROS2 Container Liveness Probe

After=docker.service sim-session.service
PartOf=sim-session.service

[Service]
Type=oneshot
RemainAfterExit=yes

ExecStart=/bin/sh -c '\
  echo "[Liveness] Checking ros2 container..."; \
  if ! docker ps --filter "name=ros2" --format "{{.Names}}" | grep -q .; then \
    echo "[Liveness] Error: ros2 container not running" >&2; \
    exit 1; \
  fi; \
  echo "[Liveness] ros2 container is running ✓"'

ExecStop=/bin/sh -c 'echo "[Liveness] Liveness probe stopped"'

Restart=no

[Install]
WantedBy=default.target
