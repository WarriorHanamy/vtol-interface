[Unit]
Description=Test Executor Service (runs inside ros2 container)
Documentation=Executes test_neural_executor launch file. Stops automatically if ros2 container exits.

BindsTo=ros2-liveness.service
After=ros2-liveness.service
PartOf=sim-session.service
Before=test.target

[Service]
Type=simple
# Dynamic container discovery - find the running ros2 container
ExecStartPre=/bin/sh -c 'CONTAINER=$$(docker ps --filter "name=ros2" --format "{{.Names}}" | head -n 1); \
if [ -z "$$CONTAINER" ]; then \
  echo "Error: ros2 container not found" >&2; \
  echo "Please start the ros2 container first using 'make sim' or 'docker compose up -d ros2'" >&2; \
  exit 1; \
fi; \
echo "$$CONTAINER"'
# Execute test_neural_executor launch file inside the ros2 container
ExecStart=/bin/sh -c 'CONTAINER=$$(docker ps --filter "name=ros2" --format "{{.Names}}" | head -n 1); \
docker exec -u ros "$$CONTAINER" /bin/bash -lc "source /opt/ros/humble/setup.bash && \
cd /home/ros/ros2_ws && \
source install/setup.bash && \
ros2 launch neural_executor test_neural_executor.launch.py"'
Restart=no

# Security settings for user service
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=test.target
